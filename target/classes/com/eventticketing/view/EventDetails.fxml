<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.eventticketing.controller.EventDetailsController">
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="10">
            <Label text="🎟 Event Ticketing System" styleClass="app-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Browse Events" styleClass="nav-button" onAction="#goToBrowse"/>
            <Button text="My Tickets" styleClass="nav-button" onAction="#goToMyTickets"/>
            <Button fx:id="cartButton" text="🛒 Cart" styleClass="nav-button" onAction="#goToCart"/>
            <Button text="Logout" styleClass="nav-button" onAction="#handleLogout"/>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox spacing="18" style="-fx-padding: 24;">
                <Button text="&#8592; Back to Events" styleClass="btn-link" onAction="#goToBrowse"/>

                <VBox styleClass="card" spacing="8">
                    <Label fx:id="badgeLabel" styleClass="badge"/>
                    <Label fx:id="titleLabel" styleClass="page-title" wrapText="true"/>
                    <Label fx:id="venueLabel" styleClass="event-card-meta"/>
                    <Label fx:id="dateLabel" styleClass="event-card-meta"/>
                    <Label fx:id="descriptionLabel" wrapText="true" style="-fx-padding: 8 0 0 0;"/>
                </VBox>

                <VBox styleClass="card" spacing="12">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="Select Seats" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Available" styleClass="event-card-meta" style="-fx-text-fill: #2E9E6D;"/>
                        <Label text="Selected" styleClass="event-card-meta" style="-fx-text-fill: #C9711A;"/>
                    </HBox>
                    <FlowPane fx:id="seatsFlowPane" hgap="8" vgap="8"/>
                    <Label fx:id="noSeatsLabel" text="No seats available for this event." managed="false" visible="false" styleClass="subtle-text"/>
                </VBox>

                <HBox styleClass="card" alignment="CENTER_LEFT" spacing="14">
                    <VBox>
                        <Label text="Selected seats" styleClass="subtle-text"/>
                        <Label fx:id="selectedCountLabel" styleClass="section-title"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <VBox alignment="CENTER_RIGHT">
                        <Label text="Total" styleClass="subtle-text"/>
                        <Label fx:id="totalLabel" styleClass="event-card-price"/>
                    </VBox>
                    <Button text="Add to Cart" styleClass="btn-primary" onAction="#handleAddToCart"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
