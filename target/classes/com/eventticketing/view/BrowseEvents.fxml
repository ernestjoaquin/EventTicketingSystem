<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.eventticketing.controller.BrowseEventsController">
    <top>
        <VBox>
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="10">
                <Label text="🎟 Event Ticketing System" styleClass="app-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Browse Events" styleClass="nav-button" onAction="#goToBrowse"/>
                <Button text="My Tickets" styleClass="nav-button" onAction="#goToMyTickets"/>
                <Label fx:id="userLabel" styleClass="user-label"/>
                <Button text="Logout" styleClass="nav-button" onAction="#handleLogout"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 18 24 10 24;">
                <Label text="Browse Events" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="searchField" promptText="Search events..." prefWidth="220"/>
                <ComboBox fx:id="categoryCombo" promptText="All Categories" prefWidth="160"/>
                <Button text="Search" styleClass="btn-secondary" onAction="#handleSearch"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <FlowPane fx:id="eventsFlowPane" hgap="18" vgap="18" style="-fx-padding: 8 24 24 24;"/>
        </ScrollPane>
    </center>
</BorderPane>
