<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.eventticketing.controller.MyTicketsController">
    <top>
        <VBox>
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="10">
                <Label text="🎟 Event Ticketing System" styleClass="app-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Browse Events" styleClass="nav-button" onAction="#goToBrowse"/>
                <Button text="My Tickets" styleClass="nav-button" onAction="#refreshView"/>
                <Button fx:id="cartButton" text="🛒 Cart" styleClass="nav-button" onAction="#goToCart"/>
                <Button text="Logout" styleClass="nav-button" onAction="#handleLogout"/>
            </HBox>
            <Label text="My Tickets" styleClass="page-title" style="-fx-padding: 18 24 10 24;"/>
        </VBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox fx:id="ticketsBox" spacing="14" style="-fx-padding: 8 24 24 24;"/>
        </ScrollPane>
    </center>
</BorderPane>
