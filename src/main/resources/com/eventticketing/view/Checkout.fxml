<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.eventticketing.controller.CheckoutController">
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="10">
            <Label text="🎟 Event Ticketing System" styleClass="app-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Browse Events" styleClass="nav-button" onAction="#goToBrowse"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="16" style="-fx-padding: 24;" maxWidth="480" alignment="TOP_CENTER">
            <Label text="Payment" styleClass="page-title"/>

            <VBox styleClass="card" spacing="10">
                <Label text="Order Summary" styleClass="section-title"/>
                <HBox>
                    <Label fx:id="eventLabel" styleClass="event-card-meta"/>
                </HBox>
                <HBox>
                    <Label fx:id="itemsLabel" styleClass="event-card-meta"/>
                </HBox>
                <HBox alignment="CENTER_LEFT">
                    <Label text="Total Amount" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="totalLabel" styleClass="event-card-price" style="-fx-font-size: 18px;"/>
                </HBox>
            </VBox>

            <VBox styleClass="card" spacing="10">
                <Label text="Payment Method" styleClass="section-title"/>
                <ComboBox fx:id="methodCombo" maxWidth="Infinity"/>
                <Label text="Card Number"/>
                <TextField fx:id="cardField" promptText="1111 2222 3333 4444"/>
                <HBox spacing="10">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Expiry"/>
                        <TextField fx:id="expiryField" promptText="MM/YY"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="CVV"/>
                        <TextField fx:id="cvvField" promptText="123"/>
                    </VBox>
                </HBox>
            </VBox>

            <Label fx:id="statusLabel" styleClass="error-text" wrapText="true" managed="false" visible="false"/>

            <Button text="Pay Now" styleClass="btn-primary" maxWidth="Infinity" onAction="#handlePay"/>
            <Button text="Back to Cart" styleClass="btn-link" onAction="#goToCart"/>
        </VBox>
    </center>
</BorderPane>
