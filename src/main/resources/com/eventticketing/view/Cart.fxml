<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.eventticketing.controller.CartController">
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="10">
            <Label text="🎟 Event Ticketing System" styleClass="app-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Browse Events" styleClass="nav-button" onAction="#goToBrowse"/>
            <Button text="My Tickets" styleClass="nav-button" onAction="#goToMyTickets"/>
            <Button text="Logout" styleClass="nav-button" onAction="#handleLogout"/>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <VBox spacing="16" style="-fx-padding: 24;" maxWidth="700">
                <Label text="Your Cart" styleClass="page-title"/>
                <Label fx:id="eventNameLabel" styleClass="section-title"/>

                <VBox fx:id="cartItemsBox" spacing="10"/>

                <Label fx:id="emptyLabel" text="Your cart is empty. Browse events to add tickets." styleClass="subtle-text" managed="false" visible="false"/>

                <HBox styleClass="card" alignment="CENTER_LEFT" spacing="14">
                    <Label text="Total" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="totalLabel" styleClass="event-card-price" style="-fx-font-size: 20px;"/>
                </HBox>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Continue Browsing" styleClass="btn-secondary" onAction="#goToBrowse"/>
                    <Button text="Proceed to Payment" styleClass="btn-primary" onAction="#handleCheckout"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
